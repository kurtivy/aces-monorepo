{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/src/vercel.ts",
      "use": "@vercel/node"
    },
    {
      "src": "apps/frontend/next.config.ts",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/backend/src/vercel.ts"
    },
    {
      "src": "/(.*)",
      "dest": "apps/frontend"
    }
  ]
}
