{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node", "chai"]
  },
  "include": ["./test/**/*.ts", "./scripts/**/*.ts", "./typechain-types/**/*.ts"],
  "files": ["./hardhat.config.ts"]
}
