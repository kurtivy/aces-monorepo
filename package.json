{
  "name": "aces-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Aces.fun - RWA tokenization platform on Base.",
  "packageManager": "pnpm@8.15.5",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:performance": "./scripts/run-performance-tests.sh",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "convert:png-to-webp": "node scripts/convert-png-to-webp.js",
    "move:png-to-old": "node scripts/move-png-to-old-outline.js",
    "convert:and-clean": "node scripts/convert-and-clean-png.js"
  },
  "pnpm": {
    "overrides": {
      "@hpke/common": "1.7.2"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.53.0",
    "prettier": "^3.2.5",
    "sharp": "^0.33.2",
    "turbo": "^1.13.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@prisma/client": "5.10.2",
    "prisma": "5.10.2"
  }
}
