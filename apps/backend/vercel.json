{
  "functions": {
    "src/vercel.ts": {
      "includeFiles": [
        "prisma/schema.prisma",
        "node_modules/.prisma/**",
        "node_modules/@prisma/**"
      ],
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm ci",
  "framework": null,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/vercel.ts"
    }
  ]
}
