{
  "version": 2,
  "buildCommand": "pnpm vercel-build",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "outputDirectory": ".",

  "functions": {
    "api/cron/sync-tokens.js": {
      "maxDuration": 30
    },
    "api/index.js": {
      "maxDuration": 30
    }
  },

  "crons": [
    {
      "path": "/api/cron/sync-tokens",
      "schedule": "* * * * *"
    }
  ],

  "rewrites": [
    {
      "source": "/health/live",
      "destination": "/api/health"
    },
    {
      "source": "/health/ready",
      "destination": "/api/health"
    },
    {
      "source": "/health/(.*)?",
      "destination": "/api/health"
    },
    {
      "source": "/api/health/(.*)?",
      "destination": "/api/health"
    },
    {
      "source": "/api/(?!cron/)(.*)",
      "destination": "/api/index"
    }
  ]
}
