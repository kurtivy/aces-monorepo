{
  "version": 2,
  "buildCommand": "pnpm vercel-build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": ".",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "dev": true
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, Accept, Origin, X-Requested-With"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/health/(.*)",
      "destination": "/api/health"
    },
    {
      "source": "/api/v1/submissions/(.*)",
      "destination": "/api/submissions"
    },
    {
      "source": "/api/v1/bids/(.*)",
      "destination": "/api/bids"
    },
    {
      "source": "/api/v1/admin/(.*)",
      "destination": "/api/admin"
    },
    {
      "source": "/api/v1/webhooks/(.*)",
      "destination": "/api/webhooks"
    },
    {
      "source": "/api/v1/listings/(.*)",
      "destination": "/api/listings"
    },
    {
      "source": "/api/v1/tokens/(.*)",
      "destination": "/api/tokens"
    },
    {
      "source": "/api/v1/users/(.*)",
      "destination": "/api/users"
    },
    {
      "source": "/api/v1/account-verification/(.*)",
      "destination": "/api/account-verification"
    },
    {
      "source": "/api/v1/contact/(.*)",
      "destination": "/api/contact"
    }
  ]
}
