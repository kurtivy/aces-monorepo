{
  "version": 2,
  "buildCommand": "pnpm vercel-build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
