{
  "version": 2,
  "buildCommand": "pnpm vercel-build",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "outputDirectory": ".",

  "functions": {
    "api/cron/sync-tokens.js": {
      "maxDuration": 30
    }
  },

  "crons": [
    {
      "path": "/api/cron/sync-tokens",
      "schedule": "* * * * *"
    }
  ],

  "rewrites": [
    {
      "source": "/health(/.*)?",
      "destination": "/api/health"
    },
    {
      "source": "/api/v1/health(/.*)?",
      "destination": "/api/health"
    },
    {
      "source": "/api/v1/submissions(/.*)?",
      "destination": "/api/submissions"
    },
    {
      "source": "/api/v1/admin(/.*)?",
      "destination": "/api/admin"
    },
    {
      "source": "/api/v1/listings(/.*)?",
      "destination": "/api/listings"
    },
    {
      "source": "/api/v1/users(/.*)?",
      "destination": "/api/users"
    },
    {
      "source": "/api/v1/verification(/.*)?",
      "destination": "/api/verification"
    },
    {
      "source": "/api/v1/contact(/.*)?",
      "destination": "/api/contact"
    }
  ]
}
