# ACES Backend API Testing Configuration
# Copy this file to test-config.env and fill in your actual values

# API Configuration
API_BASE_URL=https://aces-monorepo-backend-git-dev-dan-aces-fun.vercel.app
ENVIRONMENT=development

# Authentication (get these from your auth provider)
TEST_AUTH_TOKEN=
TEST_USER_EMAIL=test@example.com

# For testing different environments:
# Local Development:
# API_BASE_URL=http://localhost:3001

# Vercel Preview/Staging:
# API_BASE_URL=https://your-preview-deployment.vercel.app

# Vercel Production:
# API_BASE_URL=https://your-production-domain.com

# Testing Configuration
TEST_TIMEOUT=30000
VERBOSE_OUTPUT=false

# Database (if testing requires seeding)
TEST_DATABASE_URL=
