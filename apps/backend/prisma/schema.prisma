generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// Force regeneration - email field added
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  privyDid      String          @unique
  walletAddress String?         @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  email         String?         @unique
  bids          Bid[]
  RwaSubmission RwaSubmission[]

  @@map("users")
}

model Token {
  id              String        @id @default(cuid())
  contractAddress String        @unique
  deedNftId       Int
  submissionId    String        @unique
  createdAt       DateTime      @default(now())
  submission      RwaSubmission @relation(fields: [submissionId], references: [id])

  @@index([contractAddress])
  @@map("tokens")
}

model Bid {
  id            String        @id @default(cuid())
  submissionId  String
  bidderId      String
  amount        String
  createdAt     DateTime      @default(now())
  deletedAt     DateTime?
  updatedBy     String?
  updatedByType ActionType?
  currency      String
  bidder        User          @relation(fields: [bidderId], references: [id])
  submission    RwaSubmission @relation(fields: [submissionId], references: [id])

  @@unique([bidderId, submissionId])
  @@index([submissionId, createdAt])
  @@map("bids")
}

model WebhookLog {
  id          String    @id @default(cuid())
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  error       String?
  headers     Json

  @@index([processedAt, createdAt])
  @@map("webhook_logs")
}

model SubmissionAuditLog {
  id           String            @id @default(cuid())
  submissionId String
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  actorId      String
  notes        String?
  createdAt    DateTime          @default(now())
  actorType    ActionType
  submission   RwaSubmission     @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
  @@index([actorId, actorType])
  @@map("submission_audit_logs")
}

model RwaSubmission {
  id                String               @id @default(cuid())
  status            SubmissionStatus     @default(PENDING)
  txStatus          TxStatus?
  rejectionType     RejectionType?
  name              String
  symbol            String
  description       String
  imageUrl          String
  proofOfOwnership  String
  destinationWallet String?
  twitterLink       String?
  email             String?
  ownerId           String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  approvedAt        DateTime?
  rejectionReason   String?
  txHash            String?              @unique
  deletedAt         DateTime?
  updatedBy         String?
  updatedByType     ActionType?
  bids              Bid[]
  owner             User                 @relation(fields: [ownerId], references: [id])
  auditLogs         SubmissionAuditLog[]
  token             Token?

  @@index([status, createdAt])
  @@index([ownerId, createdAt])
  @@index([createdAt])
  @@index([email])
  @@map("rwa_submissions")
}

enum SubmissionStatus {
  PENDING
  APPROVED
  LIVE
  REJECTED
}

enum TxStatus {
  SUBMITTED
  MINED
  FAILED
  DROPPED
}

enum RejectionType {
  MANUAL
  TX_FAILURE
}

enum ActionType {
  USER
  SYSTEM
  WEBHOOK
  ADMIN
}
