generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                @id @default(cuid())
  privyDid              String                @unique
  walletAddress         String?               @unique
  email                 String?               @unique
  role                  UserRole              @default(TRADER)
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  reviewedVerifications AccountVerification[] @relation("ReviewedBy")
  accountVerification   AccountVerification?
  approvedSubmissions   Submission[]          @relation("ApprovedBy")
  submissions           Submission[]
  listings              Listing[]
  approvedListings      Listing[]             @relation("ApprovedBy")

  @@map("users")
}

model AccountVerification {
  id                      String             @id @default(cuid())
  userId                  String             @unique
  documentType            DocumentType
  documentNumber          String
  documentImageUrl        String?
  firstName               String
  lastName                String
  dateOfBirth             DateTime
  countryOfIssue          String
  state                   String?
  address                 String
  emailAddress            String
  status                  VerificationStatus @default(PENDING)
  submittedAt             DateTime           @default(now())
  reviewedAt              DateTime?
  reviewedBy              String?
  rejectionReason         String?
  attempts                Int                @default(1)
  lastAttemptAt           DateTime           @default(now())
  selfieImageUrl          String?
  facialComparisonScore   Float?
  visionApiRecommendation String?
  documentAnalysisResults Json?
  facialVerificationAt    DateTime?
  reviewer                User?              @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  user                    User               @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
  @@map("account_verifications")
}

model Submission {
  id                       String           @id @default(cuid())
  title                    String
  symbol                   String
  description              String
  assetType                AssetType
  imageGallery             String[]         @default([])
  location                 String?
  email                    String?
  proofOfOwnership         String
  proofOfOwnershipImageUrl String?
  typeOfOwnership          String
  status                   SubmissionStatus @default(PENDING)
  rejectionType            RejectionType?
  rejectionReason          String?
  ownerId                  String
  approvedBy               String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  approvedAt               DateTime?
  approvedByUser           User?            @relation("ApprovedBy", fields: [approvedBy], references: [id])
  owner                    User             @relation(fields: [ownerId], references: [id])
  listing                  Listing?

  @@index([status, createdAt])
  @@index([ownerId, createdAt])
  @@map("submissions")
}

model Listing {
  id                String     @id @default(cuid())

  title             String
  symbol            String
  description       String
  assetType         AssetType
  imageGallery      String[]   @default([])
  location          String?
  email             String?

  isLive            Boolean    @default(false)

  submissionId      String     @unique
  ownerId           String
  approvedBy        String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  submission        Submission @relation(fields: [submissionId], references: [id])
  owner             User       @relation(fields: [ownerId], references: [id])
  approvedByUser    User?      @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@index([isLive, createdAt])
  @@index([ownerId])
  @@map("listings")
}

enum UserRole {
  TRADER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  DRIVERS_LICENSE
  PASSPORT
  ID_CARD
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RejectionType {
  MANUAL
  TX_FAILURE
}

enum AssetType {
  VEHICLE
  JEWELRY
  COLLECTIBLE
  ART
  FASHION
  ALCOHOL
  OTHER
}
