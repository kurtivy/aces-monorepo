// prisma/schema.prisma - Step 1: User Model Only
generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  privyDid      String   @unique
  walletAddress String?  @unique
  email         String?  @unique
  
  // User Status
  role          UserRole @default(TRADER)
  isActive      Boolean  @default(true)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Account verification relationship
  accountVerification     AccountVerification?
  reviewedVerifications   AccountVerification[] @relation("ReviewedBy")

  @@map("users")
}

// Minimal enums for now
enum UserRole {
  TRADER
  ADMIN
}
model AccountVerification {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id])

  documentType     DocumentType
  documentNumber   String
  documentImageUrl String?

  firstName        String
  lastName         String
  dateOfBirth      DateTime
  countryOfIssue   String
  state            String?
  address          String
  emailAddress     String

  status           VerificationStatus @default(PENDING)
  submittedAt      DateTime           @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?
  reviewer         User?              @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  rejectionReason  String?

  attempts         Int                @default(1)
  lastAttemptAt    DateTime           @default(now())

  // Google Vision API Integration Fields
  selfieImageUrl          String?
  facialComparisonScore   Float?
  visionApiRecommendation String?
  documentAnalysisResults Json?
  facialVerificationAt    DateTime?

  @@index([status])
  @@index([userId])
  @@map("account_verifications")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  DRIVERS_LICENSE
  PASSPORT
  ID_CARD
}