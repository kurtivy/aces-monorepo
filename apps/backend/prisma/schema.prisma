// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  privyDid      String   @unique
  walletAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  rwaSubmissions RwaSubmission[]
  bids           Bid[]

  @@map("users")
}

model RwaSubmission {
  id              String            @id @default(cuid())
  name            String
  symbol          String
  description     String
  imageUrl        String
  proofOfOwnership String
  status          SubmissionStatus  @default(PENDING)
  
  // Blockchain data
  txHash          String?
  txStatus        TransactionStatus @default(PENDING)
  contractAddress String?
  tokenId         String?
  
  // Ownership
  ownerId         String
  owner           User              @relation(fields: [ownerId], references: [id])
  
  // Admin tracking
  approvedAt      DateTime?
  updatedBy       String?
  updatedByType   ActorType?
  
  // Soft delete
  deletedAt       DateTime?
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  bids            Bid[]
  auditLogs       SubmissionAuditLog[]

  @@map("rwa_submissions")
}

model Bid {
  id           String    @id @default(cuid())
  submissionId String
  submission   RwaSubmission @relation(fields: [submissionId], references: [id])
  
  bidderId     String
  bidder       User      @relation(fields: [bidderId], references: [id])
  
  amount       String    // Store as string to handle big numbers
  currency     Currency  @default(ETH)
  
  // Blockchain data
  txHash       String?
  txStatus     TransactionStatus @default(PENDING)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("bids")
}

model SubmissionAuditLog {
  id           String           @id @default(cuid())
  submissionId String
  submission   RwaSubmission    @relation(fields: [submissionId], references: [id])
  
  fromStatus   SubmissionStatus
  toStatus     SubmissionStatus
  
  actorId      String
  actorType    ActorType
  
  notes        String?
  
  createdAt    DateTime         @default(now())

  @@map("submission_audit_logs")
}

model WebhookLog {
  id          String    @id @default(cuid())
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("webhook_logs")
}

// Enums
enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  DEPLOYED
}

enum TransactionStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum Currency {
  ETH
  ACES
}

enum ActorType {
  USER
  ADMIN
  SYSTEM
} 