generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// Force regeneration - email field added
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  privyDid      String          @unique
  walletAddress String?         @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  email         String?         @unique
  
  // User Role & Status
  role          UserRole        @default(TRADER)
  isActive      Boolean         @default(true)
  
  // Profile Information  
  firstName     String?
  lastName      String?
  displayName   String?
  avatar        String?
  bio           String?
  website       String?
  twitterHandle String?
  
  // Seller Verification System
  sellerStatus  SellerStatus    @default(NOT_APPLIED)
  appliedAt     DateTime?
  verifiedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?
  
  // Seller Credentials (for protected pages)
  sellerEmail   String?         @unique // separate from main email
  sellerPasswordHash String?    // hashed password for seller dashboard
  lastSellerLogin DateTime?
  
  // Preferences & Settings
  notifications Boolean         @default(true)
  newsletter    Boolean         @default(false)
  darkMode      Boolean         @default(true)
  
  bids          Bid[]
  tokens        Token[]
  RwaSubmission RwaSubmission[]
  verification  SellerVerification?
  verificationAttempts Int @default(0)
  lastVerificationAttempt DateTime?

  @@map("users")
}

model Token {
  id              String        @id @default(cuid())
  contractAddress String        @unique
  deedNftId       Int
  submissionId    String        @unique
  userId          String        // Required field for user relationship
  createdAt       DateTime      @default(now())
  submission      RwaSubmission @relation(fields: [submissionId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([contractAddress])
  @@index([userId])
  @@map("tokens")
}

model Bid {
  id            String        @id @default(cuid())
  submissionId  String
  bidderId      String
  amount        String
  createdAt     DateTime      @default(now())
  deletedAt     DateTime?
  updatedBy     String?
  updatedByType ActionType?
  currency      String
  bidder        User          @relation(fields: [bidderId], references: [id])
  submission    RwaSubmission @relation(fields: [submissionId], references: [id])

  @@unique([bidderId, submissionId])
  @@index([submissionId, createdAt])
  @@map("bids")
}

model WebhookLog {
  id          String    @id @default(cuid())
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  error       String?
  headers     Json

  @@index([processedAt, createdAt])
  @@map("webhook_logs")
}

model SubmissionAuditLog {
  id           String            @id @default(cuid())
  submissionId String
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  actorId      String
  notes        String?
  createdAt    DateTime          @default(now())
  actorType    ActionType
  submission   RwaSubmission     @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
  @@index([actorId, actorType])
  @@map("submission_audit_logs")
}

model RwaSubmission {
  id                String               @id @default(cuid())
  status            SubmissionStatus     @default(PENDING)
  txStatus          TxStatus?
  rejectionType     RejectionType?
  name              String
  symbol            String
  description       String
  imageUrl          String?              // Made optional for backward compatibility
  imageUrls         String[]             @default([]) // Array of image URLs
  proofOfOwnership  String
  destinationWallet String?
  twitterLink       String?
  email             String?
  ownerId           String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  approvedAt        DateTime?
  rejectionReason   String?
  txHash            String?              @unique
  deletedAt         DateTime?
  updatedBy         String?
  updatedByType     ActionType?
  bids              Bid[]
  owner             User                 @relation(fields: [ownerId], references: [id])
  auditLogs         SubmissionAuditLog[]
  token             Token?

  @@index([status, createdAt])
  @@index([ownerId, createdAt])
  @@index([createdAt])
  @@index([email])
  @@map("rwa_submissions")
}

model SellerVerification {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  documentType  String      // e.g., "DRIVERS_LICENSE", "PASSPORT"
  documentNumber String
  fullName      String
  dateOfBirth   DateTime
  countryOfIssue String
  state         String?
  address       String
  emailAddress  String
  documentImageUrl String?  // URL to stored image in Supabase storage
  submittedAt   DateTime    @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?     // Admin user ID who reviewed
  status        VerificationStatus @default(PENDING)
  rejectionReason String?
  attempts      Int         @default(0)
  lastAttemptAt DateTime?
  auditLogs     VerificationAuditLog[]

  @@index([status])
  @@index([userId])
}

model VerificationAuditLog {
  id            String    @id @default(cuid())
  verificationId String
  verification  SellerVerification @relation(fields: [verificationId], references: [id])
  action        String    // e.g., "SUBMITTED", "REVIEWED", "APPROVED", "REJECTED"
  actorId       String    // User ID who performed the action
  timestamp     DateTime  @default(now())
  details       Json?     // Additional details about the action
  ipAddress     String?
  userAgent     String?

  @@index([verificationId])
  @@index([timestamp])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  LIVE
  REJECTED
}

enum TxStatus {
  SUBMITTED
  MINED
  FAILED
  DROPPED
}

enum RejectionType {
  MANUAL
  TX_FAILURE
}

enum ActionType {
  USER
  SYSTEM
  WEBHOOK
  ADMIN
}

enum UserRole {
  TRADER
  SELLER
  ADMIN
}

enum SellerStatus {
  NOT_APPLIED
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}
