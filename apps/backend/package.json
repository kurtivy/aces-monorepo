{
  "name": "@aces/backend",
  "version": "1.0.0",
  "description": "ACES Backend API - RWA submission and approval system",
  "private": true,
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "vercel-build": "npx prisma generate && npx prisma migrate deploy && tsc",
    "test": "vitest run --reporter=verbose --run",
    "test:watch": "vitest --reporter=verbose",
    "test:services": "vitest run test/services/ --reporter=verbose --run",
    "test:single": "vitest run --reporter=verbose --run",
    "coverage": "vitest run --coverage --run",
    "coverage:check": "vitest run --coverage --run && node scripts/check-coverage.js",
    "cli": "ts-node src/scripts/cli.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "clean": "rm -rf dist node_modules/.cache",
    "docker:build": "docker build -t aces-backend .",
    "docker:run": "docker run -p 3001:3001 aces-backend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aces/utils": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "^5.6.0",
    "@privy-io/server-auth": "^1.8.3",
    "fastify": "^4.24.3",
    "fastify-metrics": "^12.0.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^5.0.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.15.0",
    "under-pressure": "^6.0.0",
    "viem": "^2.16.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vitest/coverage-v8": "^0.34.6",
    "eslint": "^8.53.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
