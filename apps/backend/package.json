{
  "name": "@aces/backend",
  "version": "1.0.0",
  "description": "ACES Backend API - RWA submission and approval system",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "npx prisma generate",
    "dev": "nodemon src/dev-server.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/dev-server.js",
    "vercel-build": "npx prisma generate && tsup",
    "test": "vitest run --reporter=verbose --run",
    "test:watch": "vitest --reporter=verbose",
    "test:services": "vitest run test/services/ --reporter=verbose --run",
    "test:single": "vitest run --reporter=verbose --run",
    "test:endpoints": "node scripts/test-endpoints.js",
    "test:endpoints:verbose": "node scripts/test-endpoints.js --verbose",
    "test:api": "ts-node scripts/test-api.ts",
    "test:api:dev": "ts-node scripts/test-api.ts --env dev --verbose",
    "test:api:main": "ts-node scripts/test-api.ts --env main --verbose",
    "test:api:local": "ts-node scripts/test-api.ts --env local --verbose",
    "test:api:both": "npm run test:api:dev && npm run test:api:main",
    "coverage": "vitest run --coverage --run",
    "coverage:check": "vitest run --coverage --run && node scripts/check-coverage.js",
    "cli": "ts-node src/scripts/cli.ts",
    "set-admin": "ts-node scripts/set-admin-role.ts",
    "seed": "ts-node scripts/seed-database.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "clean": "rm -rf dist node_modules/.cache",
    "docker:build": "docker build -t aces-backend .",
    "docker:run": "docker run -p 3001:3001 aces-backend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aces/utils": "workspace:*",
    "@faker-js/faker": "^9.3.1",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^7.7.3",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/under-pressure": "^8.4.0",
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/vision": "^5.3.2",
    "@hapi/boom": "^10.0.1",
    "@prisma/client": "5.10.2",
    "@supabase/supabase-js": "^2.52.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.14.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.1",
    "fastify": "^4.24.3",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.1",
    "prisma": "5.10.2",
    "resend": "^4.7.0",
    "sharp": "^0.34.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "viem": "^2.31.6",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vercel/node": "^5.3.2",
    "@vitest/coverage-v8": "^0.34.6",
    "eslint": "^8.53.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "vitest": "^0.34.6"
  },
  "overrides": {
    "@hpke/core": "1.7.4",
    "@hpke/common": "1.8.1",
    "@hpke/chacha20poly1305": "1.6.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
